{
  "name": "@codebuff/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "codebuff": "./bin/codebuff.mjs"
  },
  "exports": {
    ".": {
      "import": "./src/index.tsx",
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    }
  },
  "scripts": {
    "dev": "npx tsx scripts/prebuild-agents.ts && npx tsx src/index.tsx --cwd ..",
    "start": "npx tsx src/index.tsx",
    "prebuild:agents": "npx tsx scripts/prebuild-agents.ts",
    "build": "node ./scripts/build-binary.ts codebuff $npm_package_version",
    "release": "npx tsx scripts/release.ts",
    "typecheck": "tsc --noEmit -p ."
  },
  "sideEffects": ["./src/pre-init/*.ts"],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@codebuff/sdk": "workspace:*",
    "@gravity-ai/api": "^0.1.2",
    "@opentui/core": "0.2.2",
    "@opentui/react": "0.2.2",
    "@tanstack/react-query": "^5.90.12",
    "commander": "^14.0.1",
    "immer": "^10.1.3",
    "jimp": "^1.6.0",
    "node-machine-id": "^1.1.12",
    "open": "^10.1.0",
    "pino": "9.4.0",
    "posthog-node": "^5.8.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "string-width": "^7.2.0",
    "systeminformation": "^5.30.7",
    "terminal-image": "^4.1.0",
    "ts-pattern": "^5.9.0",
    "unified": "^11.0.0",
    "yoga-layout": "^3.2.1",
    "zod": "^4.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.32.0",
    "esbuild": "^0.24.0",
    "react-dom": "^19.0.0",
    "strip-ansi": "^7.1.2",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0"
  }
}
